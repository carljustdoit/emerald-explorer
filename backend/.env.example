# Emerald Sourcing Engine - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API KEYS
# ===========================================

# Firecrawl API - For scraping event websites
# Get your key at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Gemini 2.0 Flash API - For AI event enrichment
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ===========================================
# AWS / CDN CONFIGURATION
# ===========================================

# AWS Region for S3
AWS_REGION=us-west-2

# AWS Credentials (use IAM with limited permissions in production)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 Bucket name for CDN
CDN_BUCKET=your-bucket-name

# Custom endpoint (for Cloudflare R2, etc.)
CDN_ENDPOINT=https://your.r2.cloudflarestorage.com

# Public URL for the CDN (optional - will be generated if not set)
CDN_PUBLIC_URL=https://cdn.yourdomain.com

# ===========================================
# LOCAL DEVELOPMENT
# ===========================================

# Output directory for local development (where to write the JSON file)
OUTPUT_DIR=../frontend/public
