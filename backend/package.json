{
  "name": "emerald-sourcing-engine",
  "version": "1.0.0",
  "description": "Backend ETL pipeline for aggregating Seattle events and environmental data",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "scrape": "tsx src/main.ts",
    "server": "tsx src/server.ts",
    "dev:server": "tsx src/server.ts",
    "deploy": "tsx src/main.ts --deploy"
  },
  "keywords": [
    "events",
    "scraping",
    "etl",
    "seattle"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.616.0",
    "@aws-sdk/lib-storage": "^3.616.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "playwright": "^1.58.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.37",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.6",
    "typescript": "^5.9.3"
  }
